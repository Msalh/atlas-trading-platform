# Copy this file to .env for local testing (never commit the real .env).
# On your hosting platform, set these as actual environment variables in its dashboard instead.

# Required as of Sprint 1 (Postgres migration). A Postgres connection string, e.g.
# postgres://user:password@host:5432/dbname. Railway's Postgres plugin injects this
# automatically once attached to the service - see docs/sprint1/deployment-checklist.md.
# The app refuses to start without this rather than silently falling back to nothing.
DATABASE_URL=

# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# A password you make up yourself. Must match the "secret" field sent in the Pine alert JSON.
WEBHOOK_SECRET=

# Optional - defaults to claude-haiku-4-5-20251001 if unset.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# The webhook URL PickMyTrade gives you for receiving trade orders. Entry events get their
# order-placement fields forwarded here automatically. If unset, entries are still stored and
# analyzed, they just won't be forwarded (pmt_forwarded will show false with an error explaining why).
PICKMYTRADE_WEBHOOK_URL=

# Comma-separated list of origins allowed to call the API cross-origin (the Next.js
# frontend). Defaults to http://localhost:3000 (local dev) if unset - set this to your
# deployed frontend's URL(s) in production.
FRONTEND_ORIGINS=

# --- Account risk (Sprint 4) - set all four before trusting /account or /api/v1/risk ---
# for a real funded account. Until all four are set, the API reports
# account_configured: false and the frontend shows a persistent warning rather than
# silently displaying risk numbers computed against placeholder defaults.

# Your real starting/reference account balance in dollars.
ACCOUNT_STARTING_BALANCE=

# Your prop firm's actual daily loss limit in dollars.
ACCOUNT_DAILY_LOSS_LIMIT=

# Your prop firm's actual trailing drawdown limit in dollars.
ACCOUNT_TRAILING_DRAWDOWN_LIMIT=

# Your actual max position size (contracts).
ACCOUNT_MAX_CONTRACTS=

# Optional - dollars per point per contract for the traded instrument. Defaults to 2.0
# (MNQ / Micro Nasdaq). Change if you ever trade a different instrument through this system.
ACCOUNT_POINT_VALUE=2.0

# --- Sprint 0 / migration-only, not read by the running app anymore ---

# Where the OLD (Sprint 0) SQLite database lives. Only read by
# scripts/migrate_sqlite_to_postgres.py, to do the one-time copy into DATABASE_URL.
# On Railway this is your mounted volume path, e.g. /data/live.db.
LIVE_DB_PATH=

# --- Testing only ---

# Points integration tests (tests/integration/) at a real, disposable Postgres
# database (TRUNCATEd between test runs - never point this at production). If unset,
# those tests are skipped automatically; the rest of the suite doesn't need this.
TEST_DATABASE_URL=

# Copy to .env.local for local development (never commit the real .env.local).
# Points the frontend at the Atlas backend it should call.
#
# Local dev against scripts/dev_seed_server.py (in-memory, seeded, no Postgres needed):
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Local dev against the real backend (uvicorn atlas.main:app, needs a real DATABASE_URL):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production:
# NEXT_PUBLIC_API_BASE_URL=https://your-app.up.railway.app

# The BFF reads the backend credential from the server-only ATLAS_API_KEY.
# Never use a NEXT_PUBLIC_-prefixed credential.
# ATLAS_API_KEY=
